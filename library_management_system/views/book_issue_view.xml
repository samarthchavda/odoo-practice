<odoo>
    <record id="book_issue_list_view" model="ir.ui.view">
        <field name="name">Book issue list</field>
        <field name="model">book.issue</field>
        <field name="arch" type="xml">
            <list>
                <field name="book_id"/>
                <field name="member_id"/>
                <field name="issue_date"/>
                <field name="return_date"/>
                <field name="status"/>
                <field name="day_issue"/>
<!--                <field name="due_date"/>-->
<!--                <field name="late_days"/>-->
<!--                <field name="fine"/>-->
            </list>
        </field>
    </record>

    <record id="book_issue_form_view" model="ir.ui.view">
        <field name="name">Book issue form</field>
        <field name="model">book.issue</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_issue_book"
                            string="Issue"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'draft'"
                    />

                    <button name="action_return_book"
                            string="Return"
                            type="object"
                            class="btn-primary/"
                            invisible="status != 'issue'"
                    />
                </header>

                <sheet>
                    <group>
                        <field name="book_id" domain="[('is_available', '=', True)]"/>
                        <field name="member_id" domain="[('is_active', '=' , True)]"/>
                        <field name="issue_date"/>
                        <field name="return_date"/>
                        <field name="status" readonly="1"/>
                        <field name="day_issue"/>
<!--                        <field name="due_date"/>-->
<!--                        <field name="late_days"/>-->
<!--                        <field name="fine"/>-->
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_issue_book" model="ir.actions.act_window">
        <field name="name">book issue</field>
        <field name="res_model">book.issue</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="issue_book_menu"
          name="Book Issue"
          action="action_issue_book"
          parent="menu_library_root"/>
</odoo>