<odoo>
    <record id="member_list_view" model="ir.ui.view">
        <field name="name">member list view</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="name"/>
                <field name="email"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="member_form_view" model="ir.ui.view">
        <field name="name">member form view</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="is_active"/>
                    </group>
                    <notebook>
                        <page string="issue books">
                            <field name="issue_book_ids" readonly="1">
                                <list>
                                    <field name="book_id"/>
                                    <field name="issue_date"/>
                                    <field name="return_date"/>
                                    <field name="day_issue"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_member" model="ir.actions.act_window">
        <field name="name">Library Members</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_member"
              name="Members"
              action="action_member"
              parent="menu_library_root"/>

</odoo>