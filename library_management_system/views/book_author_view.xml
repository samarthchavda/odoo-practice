<odoo>
    <record id="view_book_author_list" model="ir.ui.view">
        <field name="name">book.author.list</field>
        <field name="model">book.author</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_book_author_form" model="ir.ui.view">
        <field name="name">book.author.form</field>
        <field name="model">book.author</field>
        <field name="arch" type="xml">
            <form>
<!--                <div class="oe_button_box" name="button_box">-->
<!--                    <button name="action_view_book"-->
<!--                            type="object"-->
<!--                            class="oe-stat-button"-->
<!--                            icon="fa-book">-->
<!--                        <field name="book_count"-->
<!--                               string="Book"-->
<!--                               widget="statinfo"/>-->
<!--                    </button>-->
<!--                </div>-->
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <notebook>
                        <page string="Books">
                            <field name="book_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="available_qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_author" model="ir.actions.act_window">
        <field name="name">Author</field>
        <field name="res_model">book.author</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem name="author"
              id="root_author_menu"
              parent="menu_library_root"
              action="action_author"
    />

</odoo>