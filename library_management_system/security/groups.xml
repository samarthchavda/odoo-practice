<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_library_member" model="res.groups">
        <field name="name">Library Member</field>
    </record>

    <record id="group_library_librarian" model="res.groups">
        <field name="name">Library Librarian</field>
    </record>

    <record id="ir_rule_library_member" model="ir.rule">
        <field name="name">see only library member </field>
        <field name="model_id" ref="model_library_member"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups"
           eval="[(4, ref('group_library_member'))]"/>
    </record>

    <record id="ir_rule_library_member_issue_book" model="ir.rule">
        <field name="name">own issue book</field>
        <field name="model_id" ref="model_book_issue"/>
        <field name="domain_force">[('member_id.user_id', '=', user.id)]</field>
        <field name="groups"
           eval="[(4, ref('group_library_member'))]"/>
    </record>

    <record id="ir_rule_library_manager" model="ir.rule">
        <field name="name">manager see own issue book</field>
        <field name="model_id" ref="model_book_issue"/>
        <field name="domain_force">[('create_uid','=',user.id)]</field>
<!--        <field name="groups" eval="[(4, ref('group_library_librarian'))]"/>-->
    </record>

</odoo>