<odoo>
    <record id="library_book_user_rule" model="ir.rule">
        <field name="name">User Can See Own Books</field>
        <field name="model_id" ref="model_library_book"/>
        <field name="domain_force">
            [('user_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>