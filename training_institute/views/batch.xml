<odoo>
    <record id="batch_details_list_view" model="ir.ui.view">
        <field name="name">batch.details.list</field>
        <field name="model">training.batch</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="course_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="capacity"/>
            </list>
        </field>
    </record>

    <record id="batch_details_form_view" model="ir.ui.view">
        <field name="name">batch.details.form</field>
        <field name="model">training.batch</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="course_id" domain="[('is_active', '=', True)]"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="capacity"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_batch_details" model="ir.actions.act_window">
        <field name="name">batch details</field>
        <field name="res_model">training.batch</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>