<odoo>
    <record id="student_details_list_view" model="ir.ui.view">
        <field name="name">student.details.list</field>
        <field name="model">training.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="course_ids"/>
                <field name="batch_id"/>
            </list>
        </field>
    </record>

    <record id="student_details_form_view" model="ir.ui.view">
        <field name="name">student.details.form</field>
        <field name="model">training.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="age"/>
                        <field name="gender"/>
                        <field name="course_ids"/>
                        <field name="batch_id" domain="[('course_id', 'in', 'course_ids')]"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_details" model="ir.actions.act_window">
        <field name="name">student details</field>
        <field name="res_model">training.student</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>