<odoo>
    <record id="amount_deposit_list_view" model="ir.ui.view">
        <field name="name">deposit.details.list</field>
        <field name="model">bank.deposit</field>
        <field name="arch" type="xml">
            <list>
                <field name="account_id"/>
                <field name="date"/>
                <field name="deposit_amount"/>
            </list>
        </field>
    </record>

    <record id="amount_deposit_form_view" model="ir.ui.view">
        <field name="name">deposit.details.form</field>
        <field name="model">bank.deposit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_deposit"
                            string="Deposit"
                            type="object"
                            class="btn-primary"
                            invisible="status == 'done'"
                    />
                </header>
                <sheet>
                    <group>
                        <field name="account_id"/>
                        <field name="date"/>
                        <field name="deposit_amount" readonly="id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_deposit" model="ir.actions.act_window">
        <field name="name">deposit amount</field>
        <field name="res_model">bank.deposit</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_root_deposit_amount"
              name="Deposit"
              parent="transaction_menu_root"
              action="action_deposit"/>
</odoo>