<odoo>
    <record id="account_details_list_view" model="ir.ui.view">
        <field name="name">account.details.list</field>
        <field name="model">bank.account.details</field>
        <field name="arch" type="xml">
            <list>
                <field name="customer_id"/>
                <field name="account_number"/>
                <field name="account_type"/>
                <field name="balance"/>
            </list>
        </field>
    </record>

    <record id="account_details_form_view" model="ir.ui.view">
        <field name="name">aacount.details.form</field>
        <field name="model">bank.account.details</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="customer_id"/>
                        <field name="account_number"/>
                        <field name="account_type"/>
                        <field name="balance" readonly="id"/>
                    </group>
                    <notebook>
                        <page string="Deposit">
                            <field name="deposit_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="deposit_amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Withdraw">
                            <field name="withdraw_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="withdraw_amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Transaction">
                            <field name="transaction_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="to_account_id"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_account" model="ir.actions.act_window">
        <field name="name">account details</field>
        <field name="res_model">bank.account.details</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>