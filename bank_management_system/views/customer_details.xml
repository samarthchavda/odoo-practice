<odoo>
    <record id="customer_details_list_view" model="ir.ui.view">
        <field name="name">customer.details.list</field>
        <field name="model">bank.customer</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="address"/>
                <field name="city"/>
                <field name="state"/>
                <field name="aadhar_card_number"/>
                <field name="pancard_number"/>
            </list>
        </field>
    </record>

    <record id="customer_details_form_view" model="ir.ui.view">
        <field name="name">customer.details.form</field>
        <field name="model">bank.customer</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="email"/>
                    <field name="address"/>
                    <field name="city"/>
                    <field name="state"/>
                    <field name="aadhar_card_number"/>
                    <field name="pancard_number"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_customer" model="ir.actions.act_window">
        <field name="name">cutomer details</field>
        <field name="res_model">bank.customer</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_bank_management"
          name="Bank Management"
          sequence="10"/>

    <menuitem id="menu_root_customer"
              name="Customers"
              parent="menu_bank_management"
              action="action_customer"/>

    <menuitem id="menu_root_bank_account"
              name="Accounts"
              parent="menu_bank_management"
              action="action_account"/>


</odoo>