<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="loan_history_list" model="ir.ui.view">
        <field name="name">loan.history.list</field>
        <field name="model">loan.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="loan_number"/>
                <field name="customer_id"/>
                <field name="installment_no"/>
                <field name="amount"/>
                <field name="payment_date"/>
            </list>
        </field>
    </record>

    <record id="loan_history_form" model="ir.ui.view">
        <field name="name">loan.history.form</field>
        <field name="model">loan.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="loan_number"/>
                        <field name="customer_id"/>
                        <field name="installment_no"/>
                        <field name="installment_date"/>
                        <field name="payment_date"/>
                        <field name="amount"/>
                        <field name="paid_by"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loan_history" model="ir.actions.act_window">
        <field name="name">Loan History</field>
        <field name="res_model">loan.history</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_loan_history"
              name="Loan History"
              parent="menu_bank_management"
              action="action_loan_history"/>

</odoo>