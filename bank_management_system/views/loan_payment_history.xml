<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="loan_history_list" model="ir.ui.view">
        <field name="name">loan.history.list</field>
        <field name="model">loan.application</field>
        <field name="arch" type="xml">
            <list>
                <field name="loan_number"/>
                <field name="customer_id"/>
                <field name="loan_amount"/>
                <field name="monthly_emi"/>
                <field name="paid_installments"/>
                <field name="remaining_installments"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="loan_history_form" model="ir.ui.view">
        <field name="name">loan.history.form</field>
        <field name="model">loan.application</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <group>
                            <field name="loan_number" readonly="1"/>
                            <field name="customer_id" readonly="1"/>
                            <field name="loan_amount" readonly="1"/>
                            <field name="interest_rate" readonly="1"/>
                        </group>

                        <group>
                            <field name="duration" readonly="1"/>
                            <field name="monthly_emi" readonly="1"/>
                            <field name="paid_installments" readonly="1"/>
                            <field name="remaining_installments" readonly="1"/>
                            <field name="status" readonly="1"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Installments">

                            <field name="installment_ids" readonly="1">
                                <list>
                                    <field name="installment_date"/>
                                    <field name="amount"/>
                                    <field name="status"/>
                                </list>
                            </field>

                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loan_history" model="ir.actions.act_window">
        <field name="name">Loan History</field>
        <field name="res_model">loan.application</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_loan_history"
              name="Loan History"
              parent="menu_bank_management"
              action="action_loan_history"/>

</odoo>