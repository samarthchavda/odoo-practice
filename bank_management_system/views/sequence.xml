<odoo>
    <data noupdate="1">
        <record id="library_book_number" model="ir.sequence">
            <field name="name">Bank account number</field>
            <field name="code">bank.account.sequence</field>
            <field name="prefix">ACC</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_bank_transaction" model="ir.sequence">
            <field name="name">Bank Transaction</field>
            <field name="code">bank.transaction.sequence</field>
            <field name="prefix">TRN</field>
            <field name="padding">5</field>
        </record>

        <record id="loan_application_number" model="ir.sequence">
            <field name="name">loan application number</field>
            <field name="code">loan.application.sequence</field>
            <field name="prefix">LOAN</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="loan_history_number" model="ir.sequence">
            <field name="name">loan history number</field>
            <field name="code">loan.history.sequence</field>
            <field name="prefix">LH</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>