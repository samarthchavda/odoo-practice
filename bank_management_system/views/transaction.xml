<odoo>
    <record id="account_transaction_list_view" model="ir.ui.view">
        <field name="name">account.transaction.list</field>
        <field name="model">bank.transaction</field>
        <field name="arch" type="xml">
            <list>
                <field name="transaction_number"/>
                <field name="from_account_id"/>
                <field name="to_account_id"/>
                <field name="amount"/>
                <field name="date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="account_transaction_form_view" model="ir.ui.view">
        <field name="name">aacount.transaction.form</field>
        <field name="model">bank.transaction</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button name="action_transfer"
                                type="object"
                                string="Transfer"
                                class="btn-primary"
                                invisible="state != 'draft'"/>

                        <button string="Cancel"
                                special="cancel"
                                invisible="state == 'done'"/>
                    </header>
                    <group>
                        <field name="transaction_number" readonly="1"/>
                        <field name="from_account_id"/>
                        <field name="to_account_id"/>
                        <field name="amount"/>
                        <field name="date"/>
                        <field name="remarks"/>
                        <field name="state" readonly="1"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_transaction" model="ir.actions.act_window">
        <field name="name">Transactions</field>
        <field name="res_model">bank.transaction</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="transaction_menu_root"
              name="Transaction"
              parent="menu_bank_management"
              sequence="20"
    />

    <menuitem
        id="menu_root_bank_account_transaction"
        name="Transaction"
        parent="transaction_menu_root"
        action="action_transaction"/>
</odoo>