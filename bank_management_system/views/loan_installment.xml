<odoo>
    <record id="loan_installment_list" model="ir.ui.view">
        <field name="name">laon.installment.list</field>
        <field name="model">loan.installment</field>
        <field name="arch" type="xml">
            <list>
                <field name="loan_id"/>
<!--                <field name="installment_date"/>-->
                <field name="amount"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="loan_installment_form" model="ir.ui.view">
        <field name="name">laon.installment.from</field>
        <field name="model">loan.installment</field>
        <field name="arch" type="xml">

            <form>
                <header>

                    <button name="action_pay"
                            type="object"
                            string="Pay"
                            class="btn-primary"
                            invisible="status == 'paid'"/>

                    <field name="status"
                           widget="statusbar"/>

                </header>

                <sheet>
                    <group>
                        <field name="loan_id"/>
<!--                        <field name="installment_date"/>-->
                        <field name="amount"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

<!--    kanban views-->
    <record id="loan_installment_kanban_view" model="ir.ui.view">
    <field name="name">loan.installment.kanban</field>
    <field name="model">loan.installment</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="loan_id"/>
                <field name="amount"/>
                <field name="status"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="oe_kanban_details">

                                <strong>
                                    <field name="loan_id"/>
                                </strong>

                                <div class="mt-2">
                                    <b>Amount:</b>
                                    <field name="amount"/>
                                </div>

                                <div class="mt-2">
                                    <b>Status:</b>
                                    <field name="status"/>
                                </div>

                                <div class="mt-2">
                                    <span t-if="record.status.raw_value == 'paid'"
                                          class="badge bg-success">
                                        Paid
                                    </span>

                                    <span t-if="record.status.raw_value != 'paid'"
                                          class="badge bg-warning">
                                        Pending
                                    </span>
                                </div>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_loan_installment" model="ir.actions.act_window">
        <field name="name">loan installment</field>
        <field name="res_model">loan.installment</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_root_loan_installment"
              name="Loan Installment"
              parent="menu_loan_root"
              action="action_loan_installment"/>

</odoo>