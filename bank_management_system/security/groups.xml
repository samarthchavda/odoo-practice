<odoo>
    <record id="group_manager" model="res.groups">
        <field name="name">Bank branch manager</field>
        <field name="implied_ids"
           eval="[(4, ref('bank_management_system.group_cashier'))]"/>
    </record>

    <record id="group_cashier" model="res.groups">
        <field name="name"> bank cashier</field>
        <field name="implied_ids"
           eval="[(4, ref('bank_management_system.group_customer')),(4, ref('bank_management_system.group_loan_manager'))]"/>
    </record>

    <record id="group_loan_manager" model="res.groups">
        <field name="name">loan manager</field>
        <field name="implied_ids"
           eval="[(4, ref('bank_management_system.group_manager'))]"/>
    </record>

    <record id="group_customer" model="res.groups">
        <field name="name">customer </field>
    </record>
</odoo>