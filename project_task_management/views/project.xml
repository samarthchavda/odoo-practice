<odoo>
    <record id="project_details_list_view" model="ir.ui.view">
        <field name="name">project.details.list</field>
        <field name="model">my.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="budget"/>
                <field name="is_active"/>
                <field name="task_ids"/>
            </list>
        </field>
    </record>

    <record id="project_details_form_view" model="ir.ui.view">
        <field name="name">proejct.details.form</field>
        <field name="model">my.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="customer_id"/>
                        <field name="budget"/>
                        <field name="is_active"/>
                        <field name="task_ids" readonly="True"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_project_menu" model="ir.actions.act_window">
        <field name="name">My Project</field>
        <field name="res_model">my.project</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>