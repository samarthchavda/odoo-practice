<odoo>
    <record id="task_details_list_view" model="ir.ui.view">
        <field name="name">task.details.list</field>
        <field name="model">my.task</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="assignee_to"/>
                <field name="priority"/>
                <field name="estimated_hours"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="task_details_form_view" model="ir.ui.view">
        <field name="name">task.details.form</field>
        <field name="model">my.task</field>
        <field name="arch" type="xml">
            <form>
                 <header>
                    <button name="action_complete_task"
                            type="object"
                            string="Task Complete"
                            class="btn-primary"
                            invisible="status != 'in_progress'"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="assignee_to"/>
                        <field name="priority"/>
                        <field name="estimated_hours"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_task_menu" model="ir.actions.act_window">
        <field name="name">My Task</field>
        <field name="res_model">my.task</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>