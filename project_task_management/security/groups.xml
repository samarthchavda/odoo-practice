<odoo>
    <record id="group_project_manager" model="res.groups">
        <field name="name">Project Manager</field>
    </record>

    <record id="group_project_user" model="res.groups">
        <field name="name">Project User</field>
    </record>

    <record id="task_user_rule" model="ir.rule">
        <field name="name">Task user own tasks</field>
        <field name="model_id" ref="model_my_task"/>
        <field name="domain_force">[('assignee_to', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_project_user')),(4, ref('group_project_manager'))]"/>
    </record>

    <record id="task_manager_rule" model="ir.rule">
        <field name="name">Manager see own record and create</field>
        <field name="model_id" ref="model_my_project"/>
        <field name="domain_force">[('create_uid','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_project_manager')),(4, ref('group_project_user'))]"/>
    </record>
</odoo>