<odoo>
    <record id="appointment_details_list_view" model="ir.ui.view">
        <field name="name">appointment.details.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="appointment_date"/>
                <field name="fees"/>
                <field name="status"/>
                <field name="is_paid"/>
            </list>
        </field>
    </record>

    <record id="appointment_details_form_view" model="ir.ui.view">
        <field name="name">appointment.details.from</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                     <button name="action_pay_amount"
                            type="object"
                            string="pay"
                            class="btn-primary"
                            invisible="status != 'draft'"/>

                </header>
                <sheet>
                    <group>
                        <field name="patient_id"/>
                        <field name="doctor_id" domain="[('is_available','=',True)]"/>
                        <field name="appointment_date"/>
                        <field name="fees"/>
                        <field name="status"/>
                        <field name="is_paid"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_appointment_details" model="ir.actions.act_window">
        <field name="name">Hospital Appointment</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>