<odoo>
    <record id="patient_details_list_view" model="ir.ui.view">
        <field name="name">patient.details.list</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="blood_group"/>
                <field name="appointment_ids"/>
            </list>
        </field>
    </record>

    <record id="patient_details_form_view" model="ir.ui.view">
        <field name="name">patient.details.from</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="gender"/>
                        <field name="blood_group"/>
                        <field name="appointment_ids" readonly="True"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_patient_details" model="ir.actions.act_window">
        <field name="name">Hospital patient</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>